{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(ledger_http_requests_total[1m]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum by (method, endpoint) (rate(ledger_http_requests_total[1m]))",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "B"
        }
      ],
      "title": "Request Rate (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ledger_http_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ledger_http_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "p99",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, endpoint) (rate(ledger_http_request_duration_seconds_bucket[1m]))) * 1000",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "C"
        }
      ],
      "title": "Latency (p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(ledger_http_requests_total{status=~\"5..\"}[1m])) / clamp_min(sum(rate(ledger_http_requests_total[1m])), 0.0001)",
          "legendFormat": "5xx_ratio",
          "refId": "A"
        },
        {
          "expr": "sum by (status, method, endpoint) (rate(ledger_http_requests_total[1m]))",
          "legendFormat": "{{status}} {{method}} {{endpoint}}",
          "refId": "B"
        }
      ],
      "title": "Error Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Host CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (method, endpoint, status) (increase(ledger_http_requests_total{method=~\"$method\", endpoint=~\"$endpoint\"}[$__range]))",
          "format": "table",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "API Endpoint Traffic (Range Total)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "portfolio",
    "benchmark"
  ],
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(ledger_http_requests_total, method)"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(ledger_http_requests_total, endpoint)"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
